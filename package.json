{
  "name": "ais-chat",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "build:docker:chat-bot": "docker build -t ais-chat-app -f ./apps/chat-bot/Dockerfile .",
    "build:docker:admin": "docker build -t ais-chat-admin -f ./apps/admin/Dockerfile .",
    "build:docker:api": "docker build -t ais-chat-api -f ./apps/api/Dockerfile .",
    "dev": "turbo run dev",
    "dev:chat-bot": "pnpm --filter ais-chat-app dev",
    "dev:admin": "pnpm --filter ais-chat-admin dev",
    "dev:api": "pnpm --filter ais-chat-api dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "check-types": "turbo run check-types",
    "db:migrate": "pnpm --filter @ais-chat/shared db:migrate:local && pnpm --filter @ais-chat/api-database db:migrate:local",
    "db:seed": "pnpm --filter @ais-chat/api-database db:seed && pnpm --filter @ais-chat/shared db:seed",
    "db:seed:from-stage": "pnpm --filter @ais-chat/api-database db:seed:from-stage && pnpm --filter @ais-chat/shared db:seed:from-stage",
    "jira:description": "pnpm --filter ais-chat-api exec tsx ../../scripts/jira-description.ts"
  },
  "packageManager": "pnpm@11.2.2",
  "devDependencies": {
    "@ais-chat/typescript-config": "workspace:*",
    "prettier": "3.8.3",
    "turbo": "2.9.16"
  }
}
