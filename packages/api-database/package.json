{
  "name": "@ais-chat/api-database",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./utils": "./src/api-utils/index.ts",
    "./llm-model": "./src/llm-model/index.ts"
  },
  "scripts": {
    "db:generate": "dotenv -e ../../apps/api/.env.local -- drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate --config=./drizzle.config.ts",
    "db:migrate:local": "dotenv -e ../../apps/api/.env.local -- drizzle-kit migrate --config=./drizzle.config.ts",
    "db:seed": "dotenv -e ../../apps/api/.env.local -- tsx src/seed.ts",
    "db:seed:from-stage": "dotenv -e ../../apps/api/.env.local -- tsx src/seed-from-stage.ts",
    "types": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0"
  },
  "dependencies": {
    "@t3-oss/env-core": "0.13.11",
    "bcryptjs": "3.0.3",
    "drizzle-orm": "0.45.2",
    "drizzle-zod": "0.8.3",
    "nanoid": "5.1.11",
    "pg": "8.20.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "9.39.2",
    "@ais-chat/typescript-config": "workspace:*",
    "@types/node": "24.12.3",
    "@types/pg": "8.20.0",
    "dotenv-cli": "11.0.0",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.4",
    "eslint-config-turbo": "2.9.12",
    "tsx": "4.21.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.2"
  }
}
