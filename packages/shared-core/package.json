{
  "name": "@ais-chat/shared-core",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "exports": {
    "./*": "./src/*.ts"
  },
  "scripts": {
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "types": "tsc --noEmit",
    "check-types": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@sentry/core": "10.53.1"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@ais-chat/typescript-config": "workspace:*",
    "@types/node": "24.12.4",
    "@vitest/coverage-v8": "4.1.6",
    "eslint": "9.39.4",
    "eslint-config-turbo": "2.9.14",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.3",
    "vitest": "4.1.6"
  }
}
