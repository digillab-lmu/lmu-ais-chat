{
  "name": "@ais-chat/shared-core",
  "version": "0.0.1",
  "description": "Shared utilities and helpers for all apps",
  "type": "module",
  "private": true,
  "exports": {
    "./*": "./src/*.ts"
  },
  "scripts": {
    "check-types": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . --max-warnings 0",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "types": "tsc --noEmit"
  },
  "dependencies": {
    "@sentry/core": "10.55.0"
  },
  "devDependencies": {
    "@ais-chat/eslint-config": "workspace:*",
    "@ais-chat/typescript-config": "workspace:*",
    "@types/node": "24.12.4",
    "@vitest/coverage-v8": "4.1.7",
    "eslint": "9.39.4",
    "typescript": "6.0.3",
    "vitest": "4.1.7"
  }
}
