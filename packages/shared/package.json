{
  "name": "@ais-chat/shared",
  "version": "0.0.1",
  "description": "Shared application services and database schema for the chat app",
  "main": "src/index.ts",
  "type": "module",
  "private": true,
  "exports": {
    "./*": "./src/*.ts"
  },
  "scripts": {
    "check-types": "tsc --noEmit",
    "db:drop": "dotenvx run -f ../../apps/chat-bot/.env.local -- drizzle-kit drop --config=./drizzle.config.ts",
    "db:generate": "dotenvx run -f ../../apps/chat-bot/.env.local -- drizzle-kit generate --config=./drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config=./drizzle.config.ts",
    "db:migrate:local": "dotenvx run -f ../../apps/chat-bot/.env.local -- drizzle-kit migrate --config=./drizzle.config.ts",
    "db:seed": "tsx src/db/seed/index.ts",
    "db:seed:from-stage": "dotenvx run -f ../../apps/chat-bot/.env.local -- tsx src/db/seed/seed-from-stage.ts",
    "db:seed:local": "ENVIRONMENT=development dotenvx run -f ../../apps/chat-bot/.env.local -- pnpm tsx src/db/seed/index.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . --max-warnings 0",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "types": "tsc --noEmit"
  },
  "dependencies": {
    "@ais-chat/ai-core": "workspace:*",
    "@ais-chat/shared-core": "workspace:*",
    "@aws-sdk/client-s3": "3.1057.0",
    "@aws-sdk/s3-request-presigner": "3.1057.0",
    "@dotenvx/dotenvx": "1.69.2",
    "@opentelemetry/api": "1.9.1",
    "@opentelemetry/auto-instrumentations-node": "0.76.0",
    "@opentelemetry/exporter-metrics-otlp-http": "0.218.0",
    "@opentelemetry/exporter-trace-otlp-http": "0.218.0",
    "@opentelemetry/resources": "2.7.1",
    "@opentelemetry/sdk-metrics": "2.7.1",
    "@opentelemetry/sdk-node": "0.218.0",
    "@opentelemetry/sdk-trace-node": "2.7.1",
    "@opentelemetry/semantic-conventions": "1.41.1",
    "@sentry/nextjs": "10.55.0",
    "@sentry/opentelemetry": "10.55.0",
    "@t3-oss/env-core": "0.13.11",
    "@x402/core": "2.14.0",
    "@x402/evm": "2.14.0",
    "drizzle-kit": "0.31.10",
    "drizzle-orm": "0.45.2",
    "drizzle-zod": "0.8.3",
    "linkup-sdk": "3.2.2",
    "nanoid": "5.1.11",
    "next": "16.2.6",
    "pg": "8.21.0",
    "unstorage": "1.17.5",
    "uuid": "14.0.0",
    "viem": "2.51.3",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@ais-chat/eslint-config": "workspace:*",
    "@ais-chat/typescript-config": "workspace:*",
    "@types/node": "24.12.4",
    "@types/pg": "8.20.0",
    "@vitest/coverage-v8": "4.1.7",
    "eslint": "9.39.4",
    "prettier": "3.8.3",
    "prettier-eslint": "16.4.2",
    "tsx": "4.22.3",
    "typescript": "6.0.3",
    "vitest": "4.1.7"
  }
}
