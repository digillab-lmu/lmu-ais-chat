{
  "$schema": "https://turborepo.com/schema.json",
  "globalDependencies": ["**/.env.*local"],
  "globalEnv": [
    "APP_VERSION",
    "AUTH_SECRET",
    "NODE_ENV",
    "DATABASE_URL",
    "OTC_BUCKET_NAME",
    "OTC_SECRET_ACCESS_KEY",
    "OTC_ACCESS_KEY_ID",
    "OTC_S3_HOSTNAME",
    "VIDIS_CLIENT_ID",
    "VIDIS_CLIENT_SECRET",
    "VIDIS_ISSUER_URI",
    "KEYCLOAK_CLIENT_ID",
    "KEYCLOAK_CLIENT_SECRET",
    "KEYCLOAK_ISSUER",
    "DE_TEST_API_KEY",
    "API_KEY",
    "API_URL",
    "ENCRYPTION_KEY",
    "RABBITMQ_URI",
    "NEXT_RUNTIME",
    "VALKEY_URL",
    "OTEL_METRIC_EXPORT_INTERVAL",
    "OTEL_METRIC_EXPORT_TIMEOUT",
    "SENTRY_DSN",
    "SENTRY_ENVIRONMENT",
    "SENTRY_URL",
    "SENTRY_TRACES_SAMPLE_RATE",
    "SENTRY_TRACES_SAMPLE_RATE_CLIENT",
    "NEXT_PUBLIC_SENTRY_LOG_LEVEL",
    "API_DATABASE_URL",
    "DB_CACHE_TTL_SECONDS",
    "CRAWL4AI_URL",
    "LINKUP_API_KEY",
    "LLM_IONOS_API_KEY",
    "LLM_IONOS_BASE_URL",
    "LLM_GPT4OMINI_API_KEY",
    "LLM_GPT4OMINI_BASE_URL",
    "LLM_GPT5NANO_API_KEY",
    "LLM_GPT5NANO_BASE_URL",
    "API_BASE_URL",
    "API_NAME",
    "GOOGLE_APPLICATION_CREDENTIALS",
    "OTEL_EXPORTER_OTLP_METRICS_ENDPOINT",
    "OTEL_EXPORTER_OTLP_TRACES_ENDPOINT",
    "PORT",
    "SENTRY_PROFILE_SESSION_SAMPLE_RATE",
    "STAGE_DATABASE_URL",
    "LOG_LEVEL"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "passThroughEnv": ["CI", "SENTRY_AUTH_TOKEN", "SENTRY_ORG", "SENTRY_PROJECT", "SENTRY_URL"]
    },
    "build:envless": {
      "dependsOn": ["^build:envless"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "passThroughEnv": ["CI", "SENTRY_AUTH_TOKEN", "SENTRY_ORG", "SENTRY_PROJECT", "SENTRY_URL"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "persistent": true,
      "cache": false
    },
    "db:migrate": {
      "dependsOn": ["^db:migrate"],
      "env": ["API_DATABASE_URL"]
    },
    "db:seed": {
      "dependsOn": ["^db:seed"],
      "env": ["API_DATABASE_URL"]
    },
    "db:seed:from-stage": {
      "cache": false,
      "dependsOn": []
    },
    "db:generate": {
      "cache": false,
      "dependsOn": []
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "test": {
      "dependsOn": ["^test"]
    },
    "test:coverage": {
      "dependsOn": ["^test:coverage"],
      "outputs": ["coverage/**"]
    }
  }
}
