{
  "name": "ais-chat-api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "NODE_ENV=development tsx watch src/index.ts | pino-pretty",
    "clean": "find . -type d \\( -name node_modules -o -name dist -o -name .next \\) -not -path \"./.vercel/*\" -prune -exec rm -rf {} \\;",
    "start": "NODE_ENV=production tsx src/index.ts",
    "build": "tsup",
    "lint": "eslint . --max-warnings 0",
    "types": "tsc --noEmit",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest run --watch",
    "test:coverage": "vitest run --coverage",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed",
    "e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@fastify/cors": "11.2.0",
    "@fastify/multipart": "10.0.0",
    "@fastify/otel": "0.18.1",
    "@fastify/swagger": "9.7.0",
    "@fastify/swagger-ui": "5.2.6",
    "@opentelemetry/api": "1.9.1",
    "@opentelemetry/auto-instrumentations-node": "0.75.0",
    "@opentelemetry/exporter-metrics-otlp-http": "0.217.0",
    "@opentelemetry/exporter-trace-otlp-http": "0.217.0",
    "@opentelemetry/resources": "2.7.1",
    "@opentelemetry/sdk-metrics": "2.7.1",
    "@opentelemetry/sdk-node": "0.217.0",
    "@opentelemetry/sdk-trace-node": "2.7.1",
    "@opentelemetry/semantic-conventions": "1.40.0",
    "@sentry/node": "10.52.0",
    "@sentry/opentelemetry": "10.52.0",
    "@sentry/profiling-node": "10.52.0",
    "@t3-oss/env-core": "0.13.11",
    "@ais-chat/ai-core": "workspace:*",
    "@ais-chat/api-database": "workspace:*",
    "@ais-chat/shared-core": "workspace:*",
    "dotenv": "17.4.2",
    "fastify": "5.8.5",
    "fastify-graceful-shutdown": "5.0.0",
    "openai": "6.37.0",
    "pino": "10.3.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "9.39.2",
    "@playwright/test": "1.59.1",
    "@sentry/esbuild-plugin": "5.2.1",
    "@ais-chat/typescript-config": "workspace:*",
    "@types/node": "24.12.3",
    "@vitest/coverage-v8": "4.1.5",
    "eslint": "9.39.4",
    "eslint-config-turbo": "2.9.12",
    "pino-pretty": "13.1.3",
    "tsup": "8.5.1",
    "tsx": "4.21.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.2",
    "vitest": "4.1.5"
  }
}
