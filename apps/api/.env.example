# Database
API_DATABASE_URL=postgresql://ais-chat:test1234@127.0.0.1:5432/api_db

# API
API_KEY=
API_NAME=ais-chat

# Logging
SENTRY_DSN=
SENTRY_ENVIRONMENT=
# fatal, error, warn, info, debug, trace
LOG_LEVEL=

# OpenTelemetry
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://localhost:4318/v1/traces
OTEL_EXPORTER_OTLP_METRICS_ENDPOINT=http://localhost:9090/api/v1/otlp/v1/metrics

# Sentry sample rates
SENTRY_TRACES_SAMPLE_RATE=1.0
SENTRY_PROFILE_SESSION_SAMPLE_RATE=0.0

# LLM Provider Credentials (required for database seeding)
LLM_IONOS_API_KEY=
LLM_IONOS_BASE_URL=
LLM_GPT4OMINI_API_KEY=
LLM_GPT4OMINI_BASE_URL=
LLM_GPT5NANO_API_KEY=
LLM_GPT5NANO_BASE_URL=
