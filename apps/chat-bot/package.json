{
  "name": "ais-chat-app",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev -p 3000 --turbo",
    "build": "next build",
    "build:envless": "next build --experimental-build-mode compile",
    "clean": "find . -type d \\( -name node_modules -o -name dist -o -name .next \\) -not -path \"./.vercel/*\" -prune -exec rm -rf {} \\;",
    "start": "next start",
    "lint": "eslint . --max-warnings 0",
    "types": "tsc",
    "check-types": "next typegen && tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "e2e": "NODE_OPTIONS=--experimental-require-module playwright test",
    "e2e:api": "dotenvx run -f .env.local -- playwright test tests/api/",
    "e2e:api:ui": "dotenvx run -f .env.local -- playwright test tests/api/ --ui",
    "e2e:headed": "dotenvx run -f .env.local -- playwright test --headed",
    "e2e:ui": "dotenvx run -f .env.local -- playwright test --ui",
    "k6:build": "node e2e/load_test/esbuild.k6.config.mjs",
    "prek6:run": "pnpm k6:build",
    "k6:run": "dotenvx run -f .env.k6 -- k6 run",
    "prek6:run:cloud": "pnpm k6:build",
    "k6:run:cloud": "k6 cloud run -e LOADTEST_USERNAME=$LOADTEST_USERNAME -e LOADTEST_PASSWORD=$LOADTEST_PASSWORD -e LOADTEST_IDP_HINT=$LOADTEST_IDP_HINT -e LOADTEST_BASE_URL=$LOADTEST_BASE_URL"
  },
  "dependencies": {
    "@ais-chat/ai-core": "workspace:*",
    "@ais-chat/shared": "workspace:*",
    "@ais-chat/ui": "workspace:*",
    "@aws-sdk/client-s3": "3.1048.0",
    "@aws-sdk/s3-request-presigner": "3.1048.0",
    "@hookform/resolvers": "5.2.2",
    "@langchain/textsplitters": "1.0.1",
    "@mozilla/readability": "0.6.0",
    "@opentelemetry/api": "1.9.1",
    "@phosphor-icons/react": "2.1.10",
    "@radix-ui/react-alert-dialog": "1.1.15",
    "@radix-ui/react-checkbox": "1.3.3",
    "@radix-ui/react-dropdown-menu": "2.1.16",
    "@radix-ui/react-select": "2.2.6",
    "@radix-ui/react-toast": "1.2.15",
    "@radix-ui/react-tooltip": "1.2.8",
    "@sentry/nextjs": "10.53.1",
    "@t3-oss/env-nextjs": "0.13.11",
    "@tanstack/react-query": "5.100.10",
    "@tanstack/react-virtual": "3.13.24",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "date-fns": "4.1.0",
    "docx": "9.6.1",
    "drizzle-kit": "0.31.10",
    "drizzle-orm": "0.45.2",
    "drizzle-zod": "0.8.3",
    "he": "1.2.0",
    "import-in-the-middle": "3.0.1",
    "ioredis": "5.10.1",
    "isbinaryfile": "6.0.0",
    "jose": "6.2.3",
    "jsdom": "29.1.1",
    "katex": "0.16.47",
    "linkup-sdk": "2.7.0",
    "mammoth": "1.12.0",
    "markdown-it": "14.1.1",
    "nanoid": "5.1.11",
    "next": "16.2.6",
    "next-auth": "5.0.0-beta.31",
    "next-axiom": "1.10.0",
    "next-intl": "4.12.0",
    "next-themes": "0.4.6",
    "pg": "8.20.0",
    "qrcode.react": "4.2.0",
    "rabbitmq-client": "5.0.8",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-hook-form": "7.76.0",
    "react-image-crop": "11.0.10",
    "react-markdown": "10.1.0",
    "react-syntax-highlighter": "16.1.1",
    "react-textarea-autosize": "8.5.9",
    "rehype-katex": "7.0.1",
    "remark-gfm": "4.0.1",
    "remark-math": "6.0.0",
    "require-in-the-middle": "8.0.1",
    "sharp": "0.34.5",
    "tailwind-merge": "3.6.0",
    "unpdf": "1.6.2",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@ais-chat/typescript-config": "workspace:*",
    "@axe-core/playwright": "4.11.3",
    "@dotenvx/dotenvx": "1.66.0",
    "@eslint/eslintrc": "3.3.5",
    "@playwright/test": "1.60.0",
    "@svgr/webpack": "8.1.0",
    "@tailwindcss/postcss": "4.3.0",
    "@types/he": "1.2.3",
    "@types/jsdom": "28.0.3",
    "@types/k6": "2.0.0",
    "@types/katex": "0.16.8",
    "@types/markdown-it": "14.1.2",
    "@types/node": "24.12.4",
    "@types/pg": "8.20.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/react-syntax-highlighter": "15.5.13",
    "@vitejs/plugin-react": "6.0.2",
    "@vitest/coverage-v8": "4.1.6",
    "babel-plugin-react-compiler": "1.0.0",
    "esbuild": "0.28.0",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "eslint-config-prettier": "10.1.8",
    "eslint-config-turbo": "2.9.14",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-prettier": "5.5.5",
    "k6": "0.0.0",
    "playwright-core": "1.60.0",
    "postcss": "8.5.14",
    "prettier": "3.8.3",
    "prettier-eslint": "16.4.2",
    "tailwindcss": "4.3.0",
    "tailwindcss-animate": "1.0.7",
    "tsx": "4.22.1",
    "typescript": "6.0.3",
    "vitest": "4.1.6"
  }
}
