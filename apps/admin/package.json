{
  "name": "ais-chat-admin",
  "version": "0.1.0",
  "description": "Admin web application",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "next build",
    "build:envless": "next build --experimental-build-mode compile",
    "check-types": "next typegen && tsc --noEmit",
    "dev": "next dev -p 3001 --turbo",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . --max-warnings 0",
    "start": "next start"
  },
  "dependencies": {
    "@ais-chat/api-database": "workspace:*",
    "@ais-chat/shared": "workspace:*",
    "@ais-chat/ui": "workspace:*",
    "@aws-sdk/client-s3": "3.1063.0",
    "@aws-sdk/s3-request-presigner": "3.1063.0",
    "@hookform/resolvers": "5.4.0",
    "@opentelemetry/api": "1.9.1",
    "@sentry/nextjs": "10.56.0",
    "@t3-oss/env-nextjs": "0.13.11",
    "@tanstack/react-table": "8.21.3",
    "lucide-react": "1.17.0",
    "next": "16.2.7",
    "next-auth": "5.0.0-beta.31",
    "pg": "8.21.0",
    "react": "19.2.7",
    "react-csv": "2.2.2",
    "react-dom": "19.2.7",
    "react-hook-form": "7.77.0",
    "require-in-the-middle": "8.0.1",
    "sonner": "2.0.7",
    "tailwind-merge": "3.6.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@ais-chat/eslint-config": "workspace:*",
    "@ais-chat/typescript-config": "workspace:*",
    "@tailwindcss/postcss": "4.3.0",
    "@types/node": "24.13.1",
    "@types/react": "19.2.17",
    "@types/react-csv": "1.1.10",
    "@types/react-dom": "19.2.3",
    "@types/react-syntax-highlighter": "15.5.13",
    "babel-plugin-react-compiler": "1.0.0",
    "esbuild": "0.28.1",
    "eslint": "9.39.4",
    "postcss": "8.5.15",
    "prettier": "3.8.3",
    "prettier-eslint": "16.4.2",
    "tailwindcss": "4.3.0",
    "tailwindcss-animate": "1.0.7",
    "typescript": "6.0.3"
  }
}
